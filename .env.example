DBT_POSTGRES_PORT=5432
DBT_POSTGRES_USER=anime_user
DBT_POSTGRES_PASSWORD=change_me
DBT_POSTGRES_DB=anime_db

# Airflow
AIRFLOW_FERNET_KEY=
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=admin

# AniList API (no key needed for public read operations)
# ANILIST_API_URL=https://graphql.anilist.co

# MAL API (optional alternative — requires registration)
# MAL_CLIENT_ID=your_client_id_here
